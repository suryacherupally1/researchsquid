# Required — any OpenAI-compatible LLM provider
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# Per-tier model overrides (optional — defaults shown)
SQUID_LLM_MODEL_FAST=gpt-4o-mini          # cheapest: search, fetch, simple reasoning
SQUID_LLM_MODEL_BALANCED=gpt-4o           # mid: analysis, clustering, most agents
SQUID_LLM_MODEL_POWERFUL=o1               # best: synthesizer, final report

# Brave Search
BRAVE_API_KEY=...

# Inter-service auth
SQUID_API_KEY=...

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=researchsquid

# PostgreSQL
DATABASE_URL=postgresql://squid:researchsquid@postgres:5432/squid

# Redis (Celery)
REDIS_URL=redis://redis:6379

# Optional — for GPU backend
GPU_BACKEND_REPO_ROOT=/data/repos

# Optional — for bio backend
OPENFOLD_API_KEY=...
OPENFOLD_API_URL=https://...

# Optional — observability
LANGFUSE_PUBLIC_KEY=...
LANGFUSE_SECRET_KEY=...
LANGFUSE_HOST=https://cloud.langfuse.com

# Testing
SQUID_MOCK_LLM=false
