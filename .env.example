# ── LLM Configuration (OpenAI-compatible) ────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL=openai/gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# ── Per-tier model selection (same provider, different models) ────────
# If empty, falls back to OPENAI_MODEL for that tier.
JUDGE_MODEL=
FAST_MODEL=
BALANCED_MODEL=
POWERFUL_MODEL=

# ── LLM temperatures ─────────────────────────────────────────────────
TEMPERATURE_DIRECTOR=0.5
TEMPERATURE_ARCHETYPE_DESIGN=0.7
TEMPERATURE_SQUID=0.5
TEMPERATURE_REVIEWER=0.5
TEMPERATURE_CONTROLLER=0.3
TEMPERATURE_ADJUDICATOR=0.3
TEMPERATURE_COUNTER_RESPONSE=0.5
TEMPERATURE_BRIEFING=0.3
TEMPERATURE_SYNTHESIZER=0.5

# ── LLM token limits ─────────────────────────────────────────────────
MAX_TOKENS_DEFAULT=4096
MAX_TOKENS_ADJUDICATOR=256
MAX_TOKENS_COUNTER_RESPONSE=512
MAX_TOKENS_BRIEFING=512
MAX_TOKENS_SYNTHESIZER=4096
MAX_TOKENS_RETRY_CAP=16384
MAX_RETRIES_STRUCTURED=2

# ── Neo4j ─────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=researchsquid

# ── PostgreSQL ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://squid:researchsquid@localhost:5432/squid

# ── Tavily Search ─────────────────────────────────────────────────────
TAVILY_API_KEY=

# ── Sandbox ───────────────────────────────────────────────────────────
SANDBOX_IMAGE=squid-sandbox:latest
SANDBOX_TIMEOUT=60
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_NETWORK=none
SANDBOX_TIMEOUT_HARD_CAP=300
SANDBOX_STDOUT_CAP=10000
SANDBOX_STDERR_CAP=5000
SANDBOX_CPU_PERIOD=100000
SANDBOX_CPU_QUOTA=50000

# ── Research Defaults ─────────────────────────────────────────────────
DEFAULT_AGENTS=3
DEFAULT_BUDGET=500
DEFAULT_ITERATIONS=5
DATA_DIR=data/sources

# ── Agent lifecycle ───────────────────────────────────────────────────
AGENT_PAUSE_EMPTY_THRESHOLD=2
AGENT_PAUSE_SCORE_THRESHOLD=0.15
MIN_AGENT_BUDGET=2

# ── Archetype & persona limits ───────────────────────────────────────
MAX_ARCHETYPES=20
MIN_ARCHETYPES=3
ARCHETYPE_TRAIT_VARIANCE=0.1

# ── Clustering & debate ──────────────────────────────────────────────
RECLUSTER_INTERVAL=2
MIN_CLUSTERS=2
MAX_CLUSTERS=15
CLUSTER_STANCE_THRESHOLD=0.1
MAX_DEBATE_PAIRS_PER_CLUSTER=3
MAX_INTRA_CLUSTER_PEERS=3
MAX_HYPOTHESES_PER_PEER=2
MAX_ADJUDICATIONS_PER_ROUND=10

# ── Similarity & deduplication ───────────────────────────────────────
HYPOTHESIS_DEDUP_THRESHOLD=0.85
DEDUP_SEARCH_TOP_K=5

# ── Retrieval limits ─────────────────────────────────────────────────
RETRIEVAL_DEFAULT_TOP_K=15
RETRIEVAL_SOURCE_CHUNKS_TOP_K=10
RETRIEVAL_HYPOTHESES_TOP_K=10
RETRIEVAL_NOTES_TOP_K=10
RETRIEVAL_AGENT_CONTEXT_TOP_K=20

# ── Search results ───────────────────────────────────────────────────
SEARCH_MAX_RESULTS=5
SQUID_SEARCH_MAX_RESULTS=3

# ── Graph query limits ───────────────────────────────────────────────
PROVENANCE_MAX_DEPTH=10
NEIGHBOR_LIMIT=50
GRAPH_FINDINGS_LIMIT=100
GRAPH_PENDING_EXPERIMENTS_LIMIT=20
GRAPH_FINDINGS_SYNTHESIS_LIMIT=50
GRAPH_EXPERIMENT_RESULTS_LIMIT=20
GRAPH_CONTRADICTIONS_PROMPT_LIMIT=10

# ── Reputation scoring weights ───────────────────────────────────────
REPUTATION_BASELINE=0.5
REPUTATION_HYPOTHESIS_WEIGHT=0.4
REPUTATION_UPHELD_BONUS=0.05
REPUTATION_EXPERIMENT_WEIGHT=0.2
REPUTATION_PRODUCTIVITY_CAP=0.15
REPUTATION_PRODUCTIVITY_PER_ITEM=0.01
REPUTATION_EMPTY_PENALTY=0.1

# ── Belief vector weights ────────────────────────────────────────────
BELIEF_AUTHORSHIP_WEIGHT=1.0
BELIEF_SUPPORTS_WEIGHT=0.8
BELIEF_EXTENDS_WEIGHT=0.5
BELIEF_QUESTIONS_WEIGHT=-0.3
BELIEF_CONTRADICTS_WEIGHT=-0.7
BELIEF_REFUTES_WEIGHT=-1.0
BELIEF_DEPENDS_ON_WEIGHT=0.3
BELIEF_DERIVED_FROM_WEIGHT=0.4
BELIEF_FINDING_SUPPORTS_WEIGHT=0.7
BELIEF_FINDING_REFUTES_WEIGHT=-0.9
BELIEF_FINDING_INCONCLUSIVE_WEIGHT=0.0
BELIEF_FINDING_PARTIAL_WEIGHT=0.3

# ── Reviewer ─────────────────────────────────────────────────────────
REVIEWER_REFUTATION_CONFIDENCE=0.7

# ── Persona prompt thresholds ────────────────────────────────────────
PERSONA_HIGH_THRESHOLD=0.7
PERSONA_LOW_THRESHOLD=0.3
PERSONA_SOURCE_STRICTNESS_THRESHOLD=0.8

# ── Event bus ────────────────────────────────────────────────────────
EVENT_BUS_MAX_HISTORY=1000

# ── Iteration briefing ───────────────────────────────────────────────
BRIEFING_TOP_HYPOTHESES_LIMIT=10
BRIEFING_CONTRADICTIONS_LIMIT=5
